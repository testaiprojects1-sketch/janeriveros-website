            {
              "id": "n-fuente",
              "name": "fuente",
              "value": "={{ $json.fuente || \"api\" }}",
              "type": "string"
            },
            {
              "id": "n-concepto",
              "name": "concepto",
              "value": "={{ $json.concepto || $json.descripcion }}",
              "type": "string"
            },
            {
              "id": "n-monto",
              "name": "monto",
              "value": "={{ $json.monto || $json.amount }}",
              "type": "string"
            }
          ]
        }
      }
