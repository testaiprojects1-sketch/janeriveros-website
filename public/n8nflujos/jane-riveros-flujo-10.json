      "name": "Resumen de 10 líneas",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [448, 112],
      "parameters": {
        "promptType": "define",
        "text": "={{ \"Datos de la semana de mi pyme:\\n\" + JSON.stringify($input.all().map(i => i.json)) }}",
        "options": {
          "systemMessage": "Eres el analista de una pyme chilena. Resume la semana en máximo 10 líneas en español: ventas totales, gastos, tendencia vs. semana anterior si se puede inferir, lo mejor, lo preocupante y UNA recomendación concreta para esta semana. Directo y sin relleno."
        }
      },
      "executeOnce": true
